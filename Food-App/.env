# Base44 API Client Configuration
# These are read by src/lib/app-params.js and src/api/client.js
VITE_APP_ID=your-app-id-here
VITE_APP_TOKEN=your-app-token-here
VITE_FUNCTIONS_VERSION=your-functions-version-here
VITE_APP_BASE_URL=https://your-app-base-url-here

# Also used by app-params.js (Base44 SDK naming)
VITE_BASE44_APP_ID=your-app-id-here
VITE_BASE44_FUNCTIONS_VERSION=your-functions-version-here
VITE_BASE44_APP_BASE_URL=https://your-app-base-url-here
